{
	"require": {
		"craftcms/ckeditor": "^5.6.1",
		"craftcms/cms": "5.10.12",
		"nystudio107/craft-minify": "5.0.0",
		"nystudio107/craft-seomatic": "5.1.21",
		"nystudio107/craft-vite": "5.0.1",
		"vlucas/phpdotenv": "^5.4.0"
	},
	"require-dev": {
		"nystudio107/craft-autocomplete": "^1.10",
		"yiisoft/yii2-shell": "^2.0.3"
	},
	"autoload": {
		"psr-4": {
			"modules\\": "modules/"
		}
	},
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true
		},
		"sort-packages": true,
		"optimize-autoloader": true,
		"platform": {
			"php": "8.3"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"scripts": {
		"pre-craft-update": [
			"printf '\u001b[1mRunning Install/Update Cycle...\u001b[0m\n'"
		],
		"post-craft-update": [
			"@php craft install/check && php craft up --interactive=0 || exit 0",
			"@php craft install/check && php craft invalidate-tags/all --interactive=0 || exit 0",
			"printf '\u001b[1mComplete. Exiting.\u001b[0m\n'"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"pre-update-cmd": "@pre-craft-update",
		"pre-install-cmd": "@pre-craft-update",
		"post-update-cmd": "@post-craft-update",
		"post-install-cmd": "@post-craft-update"
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://composer.craftcms.com",
			"canonical": false
		}
	]
}
